# Kubernetes
NAMESPACE=dani

# Stockage S3
S3_ENDPOINT_URL=https://storage-kubernetes.iict-heig-vd.in:9000
BUCKET=nearai

# Images des Jobs lancés par l'API
BATCH_IMAGE=ghcr.io/nearai-interreg/ray-sam3:staging
SOLO_IMAGE=ghcr.io/nearai-interreg/sam3-solo:staging

# Service de segmentation interactive (up/down)
SEGMENT_URL=http://sam3-segment:8000
SEGMENT_DEPLOYMENT=sam3-segment

# Serveur HTTP
PORT=8000
V4_ADDRESS=0.0.0.0
